---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book an Appointment — Hope Essence Dental Clinic">
  <section class="section" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: white; padding: 4rem 0 3rem;">
    <div class="container" style="text-align: center;">
      <h1 style="font-family: var(--font-serif); font-size: 2.4rem; margin-bottom: 0.75rem;">Book Your Appointment</h1>
      <p style="opacity: .9; max-width: 500px; margin: 0 auto;">Choose how you'd like to book — WhatsApp, phone, or visit us.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 700px;">
      <div class="grid-3">
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">💬</div>
          <h3 style="margin-bottom: 0.5rem;">WhatsApp Booking</h3>
          <p style="font-size: .88rem; color: var(--text-light); margin-bottom: 1.25rem;">
            Chat with our booking assistant. Quick, easy, and instant confirmation.
          </p>
          <a href="https://wa.me/67578352045" target="_blank" class="btn btn-primary" style="justify-content: center; width: 100%;">
            Book via WhatsApp →
          </a>
          <p style="margin-top: 0.75rem; font-size: .8rem; color: var(--text-light);">
            Or save <strong>+675 7835 2045</strong> to your contacts and send a message.
          </p>
        </div>

        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">📞</div>
          <h3 style="margin-bottom: 0.5rem;">Call Us</h3>
          <p style="font-size: .88rem; color: var(--text-light); margin-bottom: 1.25rem;">
            Speak directly with our reception team during opening hours.
          </p>
          <a href="tel:+67578352045" class="btn btn-accent" style="justify-content: center; width: 100%;">
            Call +675 7835 2045
          </a>
          <p style="margin-top: 0.75rem; font-size: .8rem; color: var(--text-light);">
            Also available: <strong>+675 7189 4912</strong>
          </p>
        </div>

        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">📍</div>
          <h3 style="margin-bottom: 0.5rem;">Walk In</h3>
          <p style="font-size: .88rem; color: var(--text-light); margin-bottom: 1.25rem;">
            Visit our clinic in Hohola. Walk-ins welcome, no appointment needed.
          </p>
          <div style="background: var(--bg-alt); border-radius: 8px; padding: 1rem; font-size: .88rem;">
            <strong>GB Haus, Office 17</strong><br />
            Kunai Street, Hohola<br />
            Port Moresby, NCD
          </div>
          <p style="margin-top: 0.75rem; font-size: .8rem; color: var(--text-light);">
            Mon–Fri 8am–5pm · Sat 8am–1pm
          </p>
        </div>
      </div>

      <!-- WhatsApp bot info -->
      <div class="card" style="margin-top: 2rem; background: var(--primary-light); border-color: var(--primary); text-align: center; padding: 2rem;">
        <h3 style="margin-bottom: 0.75rem;">🤖 New: WhatsApp Booking Assistant</h3>
        <p style="font-size: .9rem; color: var(--text); margin-bottom: 1rem;">
          Save our number and send a message to book instantly. Our AI assistant will guide you through selecting a service, choosing a dentist, and picking a time — all on WhatsApp. No app download needed.
        </p>
        <a href="https://wa.me/67578352045" target="_blank" class="btn btn-primary">Try It Now 💬</a>
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="section" style="background: var(--bg-alt);">
    <div class="container" style="max-width: 700px;">
      <h2 class="section-title text-center" style="margin-bottom: 2rem;">What to Expect at Your Visit</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="card" style="display: flex; gap: 1rem; align-items: center;">
          <span style="background: var(--primary); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">1</span>
          <div><strong>Arrival & Registration</strong><br /><span style="font-size: .88rem; color: var(--text-light);">Arrive 10 minutes early. Bring your ID and any referral letters.</span></div>
        </div>
        <div class="card" style="display: flex; gap: 1rem; align-items: center;">
          <span style="background: var(--primary); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">2</span>
          <div><strong>Consultation</strong><br /><span style="font-size: .88rem; color: var(--text-light);">Our dentist will examine your teeth and discuss your needs.</span></div>
        </div>
        <div class="card" style="display: flex; gap: 1rem; align-items: center;">
          <span style="background: var(--primary); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">3</span>
          <div><strong>Treatment Plan</strong><br /><span style="font-size: .88rem; color: var(--text-light);">We'll explain your options, costs, and timeline — no pressure, no surprises.</span></div>
        </div>
        <div class="card" style="display: flex; gap: 1rem; align-items: center;">
          <span style="background: var(--primary); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">4</span>
          <div><strong>Treatment & Follow-up</strong><br /><span style="font-size: .88rem; color: var(--text-light);">Receive your treatment and schedule any follow-up appointments needed.</span></div>
        </div>
      </div>
    </div>
  </section>
</Layout>
