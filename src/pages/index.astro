---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home — Hope Essence Dental Clinic, Port Moresby">
  <!-- Hero -->
  <section class="hero-section">
    <div class="container hero-grid">
      <div>
        <span class="badge" style="margin-bottom: 1.5rem; display: inline-block;">Proudly 100% PNG Owned 🇵🇬</span>
        <h1 class="heading-xl" style="margin-bottom: 1.25rem;">
          Your smile,<br />our passion.
        </h1>
        <p style="font-size: 1.1rem; color: var(--text-muted); margin-bottom: 2.25rem; max-width: 440px; line-height: 1.7;">
          Quality affordable dental care for the whole family. From routine check-ups to advanced restorations — we treat every patient like family.
        </p>
        <div class="hero-ctas">
          <a href="/book" class="btn btn-gold">📅 Book Appointment</a>
          <a href="/services" class="btn btn-outline">Our Services</a>
        </div>
      </div>
      <div class="img-placeholder hero-image">
        [ DENTIST & PATIENT PHOTO ]
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section style="padding: 2.5rem 0; border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="grid-5" style="text-align: center; gap: 0.75rem;">
        <div>
          <div class="serif" style="font-size: 1.5rem; font-weight: 600; color: var(--gold-dark); letter-spacing: -0.02em;">10+</div>
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">Years Experience</div>
        </div>
        <div>
          <div class="serif" style="font-size: 1.5rem; font-weight: 600; color: var(--gold-dark); letter-spacing: -0.02em;">10</div>
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">Dental Services</div>
        </div>
        <div>
          <div class="serif" style="font-size: 1.5rem; font-weight: 600; color: var(--gold-dark); letter-spacing: -0.02em;">5.0</div>
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">★ ★ ★ ★ ★ Rating</div>
        </div>
        <div>
          <div class="serif" style="font-size: 1.5rem; font-weight: 600; color: var(--gold-dark); letter-spacing: -0.02em;">100%</div>
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">PNG Owned</div>
        </div>
        <div>
          <div class="serif" style="font-size: 1.5rem; font-weight: 600; color: var(--gold-dark); letter-spacing: -0.02em;">Mon–Sat</div>
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">Open 6 Days</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <span class="badge" style="margin-bottom: 0.75rem;">What We Offer</span>
        <h2 class="section-title">Our Services</h2>
        <p class="section-subtitle">Comprehensive dental care for every stage of life.</p>
      </div>
      <div class="grid-3">
        <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
          <svg class="icon-gold" viewBox="0 0 24 24" style="width: 32px; height: 32px; margin: 0 auto 1.25rem;"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor"/><path d="M12 8v8M8 12h8" stroke="currentColor"/></svg>
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">General Check-up</h3>
          <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">Comprehensive oral examination to keep your smile healthy.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
          <svg class="icon-gold" viewBox="0 0 24 24" style="width: 32px; height: 32px; margin: 0 auto 1.25rem;"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor"/><path d="M3 12h18M12 3v18" stroke="currentColor"/></svg>
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">Teeth Cleaning</h3>
          <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">Professional scale and polish for a cleaner, healthier smile.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
          <svg class="icon-gold" viewBox="0 0 24 24" style="width: 32px; height: 32px; margin: 0 auto 1.25rem;"><path d="M12 2l4 8 8 2-6 6 2 8-8-4-8 4 2-8-6-6 8-2 4-8z" fill="none" stroke="currentColor"/></svg>
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">Crowns & Bridges</h3>
          <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">Restore damaged teeth with quality crowns and bridgework.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
          <svg class="icon-gold" viewBox="0 0 24 24" style="width: 32px; height: 32px; margin: 0 auto 1.25rem;"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor"/><path d="M12 2v20M2 12h20" stroke="currentColor"/></svg>
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">Root Canal Therapy</h3>
          <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">Save infected teeth with professional treatment.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
          <svg class="icon-gold" viewBox="0 0 24 24" style="width: 32px; height: 32px; margin: 0 auto 1.25rem;"><path d="M12 3l2 6 6 2-5 4 2 7-5-3-5 3 2-7-5-4 6-2 2-6z" fill="none" stroke="currentColor"/></svg>
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">Teeth Whitening</h3>
          <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">Professional whitening for a brighter, confident smile.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
          <svg class="icon-gold" viewBox="0 0 24 24" style="width: 32px; height: 32px; margin: 0 auto 1.25rem;"><rect x="4" y="4" width="16" height="16" rx="2" fill="none" stroke="currentColor"/><path d="M8 12h8M12 8v8" stroke="currentColor"/></svg>
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">Buai Stain Removal</h3>
          <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">Deep cleaning to remove betel nut stains and restore your smile.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/services" class="btn btn-gold">View All 10 Services →</a>
      </div>
    </div>
  </section>

  <!-- Why Hope Essence -->
  <section class="section section-alt">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <span class="badge" style="margin-bottom: 0.75rem;">Why Choose Us</span>
        <h2 class="section-title">Hope Essence Difference</h2>
      </div>
      <div class="grid-2">
        <div class="card" style="display: flex; gap: 1.25rem; align-items: flex-start;">
          <div style="background: var(--gold-light); border-radius: 50%; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.3rem;">🏆</div>
          <div>
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text);">Affordable Excellence</h3>
            <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.7;">Quality dental care at prices that won't break the bank. We believe everyone deserves a healthy smile.</p>
          </div>
        </div>
        <div class="card" style="display: flex; gap: 1.25rem; align-items: flex-start;">
          <div style="background: var(--gold-light); border-radius: 50%; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.3rem;">👨‍⚕️</div>
          <div>
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text);">Experienced Team</h3>
            <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.7;">Our dentists bring years of experience in general and cosmetic dentistry, using modern techniques.</p>
          </div>
        </div>
        <div class="card" style="display: flex; gap: 1.25rem; align-items: flex-start;">
          <div style="background: var(--gold-light); border-radius: 50%; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.3rem;">📍</div>
          <div>
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text);">Convenient Location</h3>
            <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.7;">Located in Hohola, Port Moresby — easy to find with parking. Open six days a week.</p>
          </div>
        </div>
        <div class="card" style="display: flex; gap: 1.25rem; align-items: flex-start;">
          <div style="background: var(--gold-light); border-radius: 50%; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.3rem;">🤝</div>
          <div>
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text);">Family-Friendly</h3>
            <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.7;">We treat patients of all ages — from children's first check-ups to senior dental care.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="section section-dark" style="text-align: center;">
    <div class="container" style="max-width: 600px;">
      <span class="badge" style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); margin-bottom: 1rem;">Get Started</span>
      <h2 class="section-title" style="font-size: 2.2rem;">Ready for a healthier smile?</h2>
      <p style="color: rgba(255,255,255,0.6); margin-bottom: 2rem; font-size: 1.05rem;">Book your appointment today — it's quick and easy.</p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="/book" class="btn btn-gold" style="font-size: 1.05rem;">📅 Book Now</a>
        <a href="tel:+67578352045" class="btn btn-ghost">📞 Call +675 7835 2045</a>
      </div>
    </div>
  </section>
</Layout>
