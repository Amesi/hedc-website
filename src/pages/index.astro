---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home — Quality Dental Care in Port Moresby">
  <!-- Hero -->
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: white; padding: 5rem 0 4rem;">
    <div class="container" style="text-align: center; max-width: 750px;">
      <span style="background: rgba(255,255,255,.15); padding: .35rem 1rem; border-radius: 20px; font-size: .85rem; display: inline-block; margin-bottom: 1.5rem;">Proudly 100% PNG Owned 🇵🇬</span>
      <h1 style="font-family: var(--font-serif); font-size: 2.8rem; margin-bottom: 1rem; line-height: 1.2;">
        Your Smile, Our Passion
      </h1>
      <p style="font-size: 1.15rem; opacity: .9; margin-bottom: 2rem; max-width: 550px; margin-left: auto; margin-right: auto;">
        Quality, affordable dental care in Port Moresby. From routine check-ups to advanced procedures — we treat every patient like family.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/book" class="btn btn-accent" style="font-size: 1.05rem; padding: 0.9rem 2.5rem;">📅 Book Appointment</a>
        <a href="/services" class="btn" style="background: rgba(255,255,255,.15); color: white; border: 2px solid rgba(255,255,255,.3);">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section style="background: var(--bg-alt); padding: 1.5rem 0; border-bottom: 1px solid var(--border);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; text-align: center;">
        <div><strong style="font-size: 1.5rem; color: var(--primary);">10+</strong><br /><span style="font-size: .85rem; color: var(--text-light);">Years Experience</span></div>
        <div><strong style="font-size: 1.5rem; color: var(--primary);">10</strong><br /><span style="font-size: .85rem; color: var(--text-light);">Dental Services</span></div>
        <div><strong style="font-size: 1.5rem; color: var(--primary);">5.0</strong><br /><span style="font-size: .85rem; color: var(--text-light);">★ ★ ★ ★ ★ Rating</span></div>
        <div><strong style="font-size: 1.5rem; color: var(--primary);">100%</strong><br /><span style="font-size: .85rem; color: var(--text-light);">PNG Owned</span></div>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <h2 class="section-title">Our Dental Services</h2>
        <p class="section-subtitle" style="margin: 0 auto;">Comprehensive dental care for the whole family — from kids' check-ups to advanced restorations.</p>
      </div>
      <div class="grid-3">
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🦷</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">General Check-up</h3>
          <p style="font-size: .88rem; color: var(--text-light);">Comprehensive oral examination to keep your smile healthy.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">✨</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Teeth Cleaning</h3>
          <p style="font-size: .88rem; color: var(--text-light);">Professional scale and polish to remove plaque and tartar.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">💎</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Crowns & Bridges</h3>
          <p style="font-size: .88rem; color: var(--text-light);">Restore damaged teeth with quality crowns and bridgework.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🔬</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Root Canal Therapy</h3>
          <p style="font-size: .88rem; color: var(--text-light);">Save infected teeth with professional root canal treatment.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🌟</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Teeth Whitening</h3>
          <p style="font-size: .88rem; color: var(--text-light);">Professional whitening for a brighter, more confident smile.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🍃</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Buai Stain Removal</h3>
          <p style="font-size: .88rem; color: var(--text-light);">Deep cleaning to remove betel nut stains and restore your natural smile.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/services" class="btn btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- Why choose us -->
  <section class="section" style="background: var(--bg-alt);">
    <div class="container">
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <h2 class="section-title">Why Choose Hope Essence?</h2>
      </div>
      <div class="grid-3">
        <div class="card">
          <h3 style="margin-bottom: 0.5rem;">🏆 Affordable Excellence</h3>
          <p style="font-size: .9rem; color: var(--text-light);">Quality dental care at prices that won't break the bank. We believe everyone deserves a healthy smile.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.5rem;">👨‍⚕️ Experienced Team</h3>
          <p style="font-size: .9rem; color: var(--text-light);">Our dentists bring years of experience in general and cosmetic dentistry, using modern techniques and equipment.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.5rem;">📍 Convenient Location</h3>
          <p style="font-size: .9rem; color: var(--text-light);">Located in Hohola, Port Moresby — easy to find, with ample parking. Open six days a week.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.5rem;">🤝 Family-Friendly</h3>
          <p style="font-size: .9rem; color: var(--text-light);">We treat patients of all ages — from children's first check-ups to senior dental care. Your whole family in one place.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.5rem;">⏱ Walk-ins Welcome</h3>
          <p style="font-size: .9rem; color: var(--text-light);">Need urgent care? Walk-ins are welcome. We also offer advance booking via WhatsApp for your convenience.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.5rem;">💯 Quality Guaranteed</h3>
          <p style="font-size: .9rem; color: var(--text-light);">Rated 5 stars by our patients. We don't just treat teeth — we build relationships and lasting smiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="text-align: center;">
    <div class="container" style="max-width: 600px;">
      <h2 class="section-title">Ready for a Healthier Smile?</h2>
      <p style="color: var(--text-light); margin-bottom: 2rem;">Book your appointment today — it's quick and easy. Or give us a call.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/book" class="btn btn-primary" style="font-size: 1.05rem;">📅 Book Now</a>
        <a href="tel:+67578352045" class="btn btn-outline">📞 Call +675 7835 2045</a>
      </div>
    </div>
  </section>
</Layout>
