---
// Layout — wraps all pages with header, footer, and SEO meta
export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "Hope Essence Dental Clinic — Quality affordable dental care in Port Moresby, Papua New Guinea"} />
    <title>{title} | Hope Essence Dental Clinic</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      :root {
        --gold: #F4BE0C;
        --gold-dark: #C99A06;
        --gold-deep: #a07e05;
        --gold-light: #faf3e0;
        --gold-tint: #fdf8ec;
        --gold-glow: rgba(244, 190, 12, 0.15);
        --text: #3a2f08;
        --text-body: #5a4e2e;
        --text-muted: #8a7e5e;
        --text-on-gold: #3a2f08;
        --surface: #ffffff;
        --surface-alt: #f8f5ec;
        --surface-dark: #2a2a2a;
        --border: #ece6d8;
        --border-light: #f5f0e6;
        --topbar-footer: #333333;
        --whatsapp: #1faf6f;
        --radius-sm: 6px;
        --radius: 10px;
        --radius-lg: 16px;
        --radius-xl: 24px;
        --shadow-gold: rgba(244, 190, 12, 0.2) 0px 4px 14px -2px, rgba(0,0,0,0.06) 0px 2px 6px -2px;
        --shadow-gold-lg: rgba(244, 190, 12, 0.15) 0px 20px 60px -20px, rgba(0,0,0,0.08) 0px 10px 30px -10px;
        --shadow-card: rgba(0,0,0,0.04) 0px 2px 8px, rgba(0,0,0,0.02) 0px 1px 2px;
        --shadow-card-hover: rgba(244, 190, 12, 0.15) 0px 12px 40px -12px, rgba(0,0,0,0.08) 0px 4px 12px -4px;
        --shadow-nav: rgba(0,0,0,0.06) 0px 1px 3px;
        --font-serif: 'Playfair Display', Georgia, serif;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --max-width: 1100px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font-sans);
        color: var(--text-body);
        background: var(--surface);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      a { color: var(--gold-dark); text-decoration: none; transition: color 0.2s; }
      a:hover { color: var(--gold); }
      img { max-width: 100%; height: auto; }
      .container { max-width: var(--max-width); margin: 0 auto; padding: 0 2rem; }

      /* ── Top bar ────────────────────────────────────── */
      .top-bar {
        background: var(--topbar-footer);
        color: rgba(255,255,255,0.75);
        font-size: 0.78rem;
        padding: 0.5rem 0;
        letter-spacing: 0.01em;
      }
      .top-bar .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .top-bar a { color: rgba(255,255,255,0.85); }
      .top-bar a:hover { color: var(--gold); }
      .top-bar .sep { opacity: 0.35; margin: 0 0.5rem; }

      /* ── Header / Nav ──────────────────────────────── */
      header {
        background: rgba(255,255,255,0.92);
        border-bottom: 1px solid var(--border-light);
        position: sticky; top: 0; z-index: 100;
        backdrop-filter: blur(16px) saturate(180%);
        box-shadow: var(--shadow-nav);
      }
      nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.85rem 0; gap: 1rem;
      }
      .logo {
        display: flex; align-items: center; gap: 0.7rem;
        font-family: var(--font-serif); font-size: 1.3rem; font-weight: 600;
        color: var(--text); white-space: nowrap; line-height: 1.2;
      }
      .logo-icon {
        width: 38px; height: 38px; border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-serif); font-weight: 700;
        font-size: 1.15rem; color: var(--text-on-gold); flex-shrink: 0;
        box-shadow: var(--shadow-gold);
      }
      .logo-sub {
        font-family: var(--font-sans);
        font-size: 0.65rem;
        font-weight: 400;
        color: var(--text-muted);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: block;
        margin-top: -1px;
      }
      .nav-links { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
      .nav-links a {
        padding: 0.45rem 1rem; border-radius: var(--radius-sm); font-size: 0.88rem; font-weight: 500;
        color: var(--text-body); transition: all 0.2s; letter-spacing: 0.01em;
      }
      .nav-links a:hover { background: var(--gold-light); color: var(--gold-dark); }
      .nav-cta {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        color: var(--text-on-gold) !important;
        padding: 0.5rem 1.25rem; border-radius: var(--radius-sm); font-weight: 600;
        box-shadow: var(--shadow-gold);
      }
      .nav-cta:hover { background: linear-gradient(135deg, var(--gold-dark), var(--gold-deep)) !important; transform: translateY(-1px); box-shadow: var(--shadow-gold-lg); }

      /* ── Buttons ───────────────────────────────────── */
      .btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.75rem 1.75rem; border-radius: var(--radius-sm); font-weight: 500;
        font-size: 0.95rem; border: none; cursor: pointer; transition: all 0.25s;
        font-family: var(--font-sans); letter-spacing: 0.01em;
      }
      .btn-gold {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        color: var(--text-on-gold); box-shadow: var(--shadow-gold);
      }
      .btn-gold:hover { background: linear-gradient(135deg, var(--gold-dark), var(--gold-deep)); transform: translateY(-1px); box-shadow: var(--shadow-gold-lg); }
      .btn-gold-pulse {
        animation: btnGlow 2.5s ease-in-out infinite;
      }
      @keyframes btnGlow {
        0%, 100% { box-shadow: var(--shadow-gold); }
        50% { box-shadow: 0 0 20px rgba(244, 190, 12, 0.4), 0 0 40px rgba(244, 190, 12, 0.15); }
      }
      .btn-whatsapp { background: var(--whatsapp); color: white; }
      .btn-whatsapp:hover { background: #0d9452; color: white; transform: translateY(-1px); }
      .btn-outline {
        background: transparent; color: var(--text-body);
        border: 1.5px solid var(--border); font-weight: 400;
      }
      .btn-outline:hover { border-color: var(--gold); background: var(--gold-light); color: var(--gold-dark); }
      .btn-ghost {
        background: rgba(255,255,255,0.1); color: white;
        border: 1.5px solid rgba(255,255,255,0.2); font-weight: 400;
      }
      .btn-ghost:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }

      /* ── Typography helpers ─────────────────────────── */
      .serif { font-family: var(--font-serif); }
      .text-center { text-align: center; }
      .text-muted { color: var(--text-muted); }
      .heading-xl {
        font-family: var(--font-serif); font-size: 4rem; font-weight: 400;
        line-height: 1.05; letter-spacing: -0.025em; color: var(--text);
      }
      .heading-lg {
        font-family: var(--font-serif); font-size: 2.75rem; font-weight: 400;
        line-height: 1.12; letter-spacing: -0.015em; color: var(--text);
      }
      .heading-md {
        font-family: var(--font-serif); font-size: 1.75rem; font-weight: 400;
        line-height: 1.25; color: var(--text);
      }
      .section-title {
        font-family: var(--font-serif); font-size: 2.75rem; font-weight: 400;
        line-height: 1.12; letter-spacing: -0.015em; margin-bottom: 0.75rem; color: var(--text);
      }
      .section-subtitle {
        color: var(--text-muted); font-size: 1.05rem; font-weight: 400;
        max-width: 560px; margin: 0 auto;
      }
      .hero-grid {
        display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center;
      }
      .hero-section {
        background: var(--gold-tint); padding: 5rem 0;
      }
      .hero-section .badge { margin-bottom: 1.5rem; display: inline-block; }
      .hero-section h1 { margin-bottom: 1.25rem; }
      .hero-section p { font-size: 1.1rem; color: var(--text-muted); margin-bottom: 2.25rem; max-width: 440px; line-height: 1.7; }
      .hero-image {
        min-height: 380px; border-radius: var(--radius-lg); box-shadow: var(--shadow-gold-lg);
      }
      .hero-ctas {
        display: flex; gap: 0.75rem; flex-wrap: wrap;
      }
      .section { padding: 5rem 0; }
      .section-alt { background: var(--surface-alt); }
      .section-dark { background: var(--surface-dark); color: rgba(255,255,255,0.85); }
      .section-dark .section-title { color: white; }
      .section-dark .section-subtitle { color: rgba(255,255,255,0.6); }

      /* ── Gold gradient section dividers ────────────── */
      .section-divider { height: 3px; background: linear-gradient(90deg, transparent, var(--gold), var(--gold-dark), var(--gold), transparent); border: none; margin: 0; }

      /* ── Card top border accent ────────────────────── */
      .card-accent {
        border-top: 3px solid transparent;
        border-image: linear-gradient(90deg, var(--gold), var(--gold-dark)) 1;
      }

      /* ── Gold pull quote ───────────────────────────── */
      .gold-quote { color: var(--gold-dark); font-family: var(--font-serif); font-weight: 600; }

      /* ── Cards ──────────────────────────────────────── */
      .card {
        background: var(--surface); border: 1px solid var(--border-light);
        border-radius: var(--radius-lg); padding: 2rem;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: var(--shadow-card);
      }
      .card:hover {
        box-shadow: var(--shadow-card-hover);
        border-color: var(--gold);
        transform: translateY(-2px);
      }
      .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
      .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.5rem; }
      .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.25rem; }
      .grid-5 { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; }
      .badge {
        display: inline-block; padding: 0.2rem 0.7rem; border-radius: 20px;
        font-size: 0.78rem; font-weight: 500; background: var(--gold-light); color: var(--gold-dark);
      }
      .price-badge {
        display: inline-block; padding: 0.15rem 0.65rem; border-radius: 4px;
        font-size: 0.82rem; font-weight: 600; background: var(--gold); color: var(--text-on-gold);
        letter-spacing: 0.02em;
      }

      /* ── Icons ──────────────────────────────────────── */
      .icon-gold {
        stroke: var(--gold); stroke-width: 1.8; fill: none;
        width: 28px; height: 28px; flex-shrink: 0;
      }

      /* ── Image placeholders ──────────────────────────── */
      .img-placeholder {
        background: repeating-linear-gradient(-45deg, var(--border-light), var(--border-light) 2px, transparent 2px, transparent 8px);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        display: flex; align-items: center; justify-content: center;
        color: var(--text-muted); font-size: 0.78rem;
        font-family: ui-monospace, monospace; text-transform: uppercase;
        letter-spacing: 0.04em; min-height: 200px;
      }

      /* ── Footer ──────────────────────────────────────── */
      footer {
        background: var(--topbar-footer); color: rgba(255,255,255,0.65);
        padding: 3.5rem 0 2rem; font-size: 0.88rem; line-height: 1.8;
      }
      footer .container { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2.5rem; }
      footer h4 { color: white; font-family: var(--font-serif); font-size: 1rem; font-weight: 400; margin-bottom: 1rem; }
      footer a { color: rgba(255,255,255,0.6); }
      footer a:hover { color: var(--gold); }
      .footer-logo {
        width: 38px; height: 38px; border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        display: inline-flex; align-items: center; justify-content: center;
        font-family: var(--font-serif); font-weight: 700;
        font-size: 1rem; color: var(--text-on-gold); margin-bottom: 0.75rem;
        box-shadow: var(--shadow-gold);
      }
      .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); margin-top: 2.5rem; padding-top: 1.5rem; text-align: center; font-size: 0.8rem; color: rgba(255,255,255,0.35); }

      @media (max-width: 768px) {
        .container { padding: 0 1rem; }
        .heading-xl { font-size: 1.8rem; letter-spacing: -0.01em; }
        .heading-lg, .section-title { font-size: 1.5rem; }
        .section { padding: 2rem 0; }
        .section-title { margin-bottom: 0.5rem; }
        .section-subtitle { font-size: 0.9rem; max-width: 100%; }
        footer .container { grid-template-columns: 1fr; gap: 1.5rem; }
        nav { flex-wrap: wrap; gap: 0.4rem; }
        .logo { font-size: 1rem; }
        .logo-icon { width: 28px; height: 28px; font-size: 0.85rem; }
        .logo-sub { font-size: 0.55rem; }
        .nav-links { order: 3; width: 100%; justify-content: center; gap: 0.1rem; }
        .nav-links a { font-size: 0.75rem; padding: 0.3rem 0.5rem; }
        .nav-cta { font-size: 0.75rem; padding: 0.35rem 0.75rem; }
        .top-bar .container { justify-content: center; text-align: center; flex-direction: column; gap: 0.15rem; }
        .top-bar { font-size: 0.65rem; padding: 0.35rem 0; }
        .grid-2, .grid-3, .grid-4, .grid-5 { gap: 0.75rem; }
        .card { padding: 1rem; border-radius: var(--radius); }
        .card h3 { font-size: 0.9rem !important; }
        .card p { font-size: 0.82rem !important; }
        .img-placeholder { min-height: 130px; font-size: 0.65rem; border-radius: var(--radius); }
        .btn { padding: 0.6rem 1.25rem; font-size: 0.85rem; }
        .badge { font-size: 0.7rem; padding: 0.15rem 0.5rem; }
        .price-badge { font-size: 0.75rem; }
        footer { padding: 2.5rem 0 1.5rem; }
        footer .container { gap: 1.25rem; }
      }
      /* m */
    </style>

    <!-- Animations: scroll reveal, shimmer, counters -->
    <style is:inline>
      .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }
      .reveal-delay-4 { transition-delay: 0.4s; }
      .reveal-delay-5 { transition-delay: 0.5s; }
      .reveal-delay-6 { transition-delay: 0.6s; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1 !important; transform: none !important; }
      }
    </style>
  </head>
  <body>
    <!-- Top bar -->
    <div class="top-bar">
      <div class="container">
        <span><a href="tel:+67578352045">📞 +675 7835 2045</a></span>
        <span>
          <span>Mon–Fri 8am–5pm</span><span class="sep">·</span><span>Sat 8am–1pm</span>
        </span>
      </div>
    </div>

    <!-- Header -->
    <header>
      <div class="container">
        <nav>
          <a href="/" class="logo">
            <span class="logo-icon">H</span>
            <span>
              Hope Essence
              <span class="logo-sub">Dental Clinic</span>
            </span>
          </a>
          <div class="nav-links">
            <a href="/">Home</a>
            <a href="/services">Services</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="/book" class="nav-cta btn-gold-pulse">Book Now</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div>
          <div class="footer-logo">H</div>
          <p style="margin-bottom: 0.75rem; max-width: 360px;">
            Quality affordable dental care in Port Moresby. Proudly 100% PNG-owned and operated since 2021.
          </p>
          <p>📍 GB Haus, Office 17, Kunai Street</p>
          <p>Section 5, Lot 225, Hohola, Port Moresby</p>
        </div>
        <div>
          <h4>Links</h4>
          <p><a href="/">Home</a></p>
          <p><a href="/services">Services</a></p>
          <p><a href="/about">About Us</a></p>
          <p><a href="/contact">Contact</a></p>
          <p><a href="/book">Book Appointment</a></p>
        </div>
        <div>
          <h4>Contact</h4>
          <p><a href="tel:+67578352045">+675 7835 2045</a></p>
          <p><a href="tel:+67571894912">+675 7189 4912</a></p>
          <p><a href="tel:+67572928301">+675 7292 8301</a></p>
          <p style="margin-top: 0.75rem;">
            <a href="mailto:hopeessencedentalclinic@gmail.com">hopeessencedentalclinic@gmail.com</a>
          </p>
          <p style="margin-top: 0.5rem;">🕐 Mon–Fri 8am–5pm</p>
          <p>🕐 Sat 8am–1pm</p>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container">&copy; {new Date().getFullYear()} Hope Essence Dental Clinic. All rights reserved.</div>
      </div>
    </footer>

    <!-- Animation scripts: scroll reveal + counters -->
    <script is:inline>
    (function(){
      // 1. Scroll reveal: observe all .reveal elements
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

      // 2. Counter: observe .counter elements, animate numbers
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            const target = parseInt(el.getAttribute('data-target') || el.textContent.replace(/[^0-9]/g, ''), 10);
            if (!target) return;
            let current = 0;
            const step = Math.max(1, Math.floor(target / 40));
            const timer = setInterval(() => {
              current += step;
              if (current >= target) { current = target; clearInterval(timer); }
              el.textContent = current + (el.getAttribute('data-suffix') || '');
            }, 30);
            counterObserver.unobserve(el);
          }
        });
      }, { threshold: 0.5 });

      // Start observing after DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else { init(); }

      function init() {
        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
        document.querySelectorAll('.counter').forEach(el => {
          el.setAttribute('data-target', el.textContent.replace(/[^0-9]/g, ''));
          el.setAttribute('data-suffix', el.textContent.replace(/[0-9]/g, ''));
          counterObserver.observe(el);
        });

        // Inject mobile CSS override after external stylesheets have loaded
        var ms = document.createElement('style');
        ms.textContent = '@media (max-width:768px){.hero-grid{grid-template-columns:1fr!important;gap:.75rem!important}.hero-image{min-height:140px!important;max-height:180px!important;order:-1!important}.hero-section .badge{margin-bottom:.5rem!important;font-size:.72rem!important}.hero-section p{font-size:.9rem!important;margin-bottom:1rem!important}.hero-ctas{flex-direction:column!important;gap:.5rem!important}.hero-ctas .btn{width:100%!important;justify-content:center!important}.hero-section{padding:2rem 0!important}.heading-xl{font-size:1.8rem!important}.section{padding:2rem 0!important}}';
        document.head.appendChild(ms);
      }
    })();
    </script>
  </body>
</html>
